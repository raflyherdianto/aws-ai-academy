# Port untuk menjalankan server Go
PORT=8080

# Kunci rahasia untuk menandatangani JWT token. 
# Ganti dengan string acak yang panjang di environment produksi
JWT_SECRET=your-secure-random-jwt-secret

# Daftar origin yang diizinkan untuk mengakses API via CORS, pisahkan dengan koma
ALLOWED_ORIGINS=http://localhost:5173,https://fasilrafly.cobalab.web.id
